@model ProductModel
@{
    ViewData["Title"] = "CreateProduct";
}

<h1>CreateProduct</h1>
<hr />
<form asp-controller="Admin" asp-action="CreateProduct" method="post">
   @* <div class="mb-3 col-md-6 offset-md-3">
        <label for="exampleFormControlInput1" class="form-label">Product Name</label>
        <input type="text" class="form-control" name="Name" placeholder="ProductName">
    </div>*@
    <div class="mb-3 col-md-6 offset-md-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" placeholder="ProductName">
    </div>

    <div class="mb-3 col-md-6 offset-md-3">
        <label asp-for="ImageUrl" class="form-label"></label>
        <input asp-for="ImageUrl" class="form-control" placeholder="ImageUrl">
    </div>
    <div class="mb-3 col-md-6 offset-md-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea id="editor" class="form-control" asp-for="Description" placeholder="Description"></textarea>
    </div>
    <div class="mb-3 col-md-6 offset-md-3">
        <label asp-for="Price" class="form-label"></label>
        <input class="form-control" asp-for="Price" placeholder="Price">
    </div>
    <div class="mb-3 col-md-6 offset-md-3">
        <button type="submit" class="btn btn-primary">Save Product</button>
    </div>
</form>
