@model ProductModel
@{
    ViewData["Title"] = "EditProduct";
}

<h1>EditProduct</h1>
<hr />
<form asp-controller="Admin" asp-action="EditProduct" method="post">
    <div class="row">
        <div class="col-md-8">
            <div class="mb-3 col-md-6 offset-md-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" placeholder="ProductName">
            </div>

            <div class="mb-3 col-md-6 offset-md-3">
                <label asp-for="ImageUrl" class="form-label"></label>
                <input asp-for="ImageUrl" class="form-control" placeholder="ImageUrl">
            </div>
            <div class="mb-3 col-md-6 offset-md-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea id="editor" class="form-control" asp-for="Description" placeholder="Description"></textarea>
            </div>
            <div class="mb-3 col-md-6 offset-md-3">
                <label asp-for="Price" class="form-label"></label>
                <input class="form-control" asp-for="Price" placeholder="Price">
            </div>
            <div class="mb-3 col-md-6 offset-md-3">
                <button type="submit" class="btn btn-primary">Save Product</button>
            </div>
        </div>
        <div class="col-md-4">
            @foreach (var item in (List<Category>)ViewBag.Categories)
            {
                <div class="form-check">
                    <input class="form-check-input" 
                    type="checkbox" 
                    name="categoryIds"
                    value="@item.Id" 
                    id="category@(item.Id)" 
                    @(Model.SelectedCategories.Any(i=> i.Id==item.Id)?"checked":"")>
                    <label class="form-check-label" for="category@(item.Id)">
                        @item.Name
                    </label>
                </div>
            }
        </div>
    </div>

</form>

